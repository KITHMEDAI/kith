# ── Kith environment variables ───────────────────────────────────────────────
# Copy to .env.local for dev, and set ALL of these in Vercel (Project → Settings
# → Environment Variables) for production. NEVER commit real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://kith.space          # production domain
INTERNAL_API_SECRET=                            # any long random string
NEXTAUTH_SECRET=                                # any long random string
NEXT_PUBLIC_USE_MOCK=false
CRON_SECRET=                                    # any long random string (Vercel Cron auth)
ENCRYPTION_SECRET=                              # long random string — enables PHI field encryption

# AI / transcription
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Online sessions (Recall.ai)
RECALL_API_KEY=
RECALL_REGION=us-east-1
RECALL_WEBHOOK_SECRET=

# Google (Calendar + Meet + Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://kith.space/api/google-calendar/callback

# Billing (Razorpay)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Patient messaging (Twilio: SMS + WhatsApp) and email (Resend)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@kith.space

# Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
